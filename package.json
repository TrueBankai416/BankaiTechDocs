{
  "name": "home-lab-docs",
  "version": "3.10.1",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "build:check": "npm run format:check && npm run lint && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "changelog:docs": "node scripts/update-doc-changelog.mjs",
    "typecheck": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,mdx}\"",
    "spell": "cspell \"**/*.{md,mdx,ts,tsx,js,jsx}\"",
    "links": "markdown-link-check --config .markdownlinkcheck.json **/*.md"
  },
  "dependencies": {
    "@docsearch/js": "^4.6.3",
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/faster": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/theme-live-codeblock": "^3.10.1",
    "@docusaurus/theme-mermaid": "^3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@iconify/react": "^6.0.2",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "discord-webhook-node": "^1.1.8",
    "discord.js": "^14.26.4",
    "disqus-react": "^1.1.7",
    "dotenv": "^17.4.2",
    "posthog-docusaurus": "^2.0.5",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "swizzle": "^1.1.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "@docusaurus/types": "^3.10.1",
    "@eslint/js": "^10.0.1",
    "@giscus/react": "^3.1.0",
    "@rspack/cli": "^2.0.3",
    "@rspack/core": "^1.7.6",
    "cspell": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "markdown-link-check": "^3.14.2",
    "prettier": "^3.8.3",
    "process": "^0.11.10",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
